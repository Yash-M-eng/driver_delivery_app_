# Copy to a local file (never commit real values):
#   cp .env.example .env
#
# Supabase — same values as Dashboard → Project Settings → API
# ("Project URL" and the anon / publishable key). Do not use the service_role key in the app.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional: maps (Distance Matrix / directions)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# Legacy names (optional). If set, they are used when SUPABASE_* above are empty.
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_ANON_KEY=

# --- Do not add to this file or to .env used by the app ---
# SUPABASE_SERVICE_ROLE_KEY  → server / Edge Functions only; never in the mobile client.
