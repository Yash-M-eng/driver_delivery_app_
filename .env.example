# Local Supabase (uncomment when using CLI)
# EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# EXPO_PUBLIC_SUPABASE_KEY=your-local-publishable-key

# LAN IP for a device hitting your machine (replace with your host IP)
# EXPO_PUBLIC_SUPABASE_URL=http://192.168.x.x:54321
# EXPO_PUBLIC_SUPABASE_KEY=your-local-publishable-key
# EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

